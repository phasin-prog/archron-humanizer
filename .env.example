# =============================================================================
# ARCHRON — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ห้าม commit .env.local ลง repo — มันอยู่ใน .gitignore แล้ว
#
# หลักการใช้:
#   .env          = ค่าเริ่มต้นที่แชร์กันได้ (URL, paths, defaults)
#                   ติดตามใน git (.env* อยู่ใน .gitignore แต่ควร commit เฉพาะค่าที่ไม่ลับ)
#   .env.local    = ค่าจริงเฉพาะ dev (secrets, API keys)
#                   ห้าม commit เด็ดขาด
# =============================================================================

# --- Clerk Auth ---
# จำเป็นสำหรับ: authentication ทั้งระบบ
# จาก Clerk Dashboard > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# เส้นทาง login/register ที่กำหนดเอง
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/th/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/th/register

# --- Supabase Database ---
# จำเป็นสำหรับ: ข้อมูลเนื้อหา (articles, thinkers, concepts, etc.)
# จาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — ใช้เฉพาะ server-side ที่ตรวจสิทธิ์แล้ว (ห้าม expose ฝั่ง client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Cloudflare R2 Storage ---
# จำเป็นสำหรับ: อัปโหลด/แสดงรูปภาพและ media files
# จาก Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=archron
# URL สาธารณะของ bucket
# เปิดใน R2 > bucket > Settings > Public access
# หรือใช้ custom domain เช่น https://assets.archron.app
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-...r2.dev

# --- Resend Email ---
# จำเป็นสำหรับ: ส่งอีเมล (แจ้งเตือน, ยืนยันตัวตน ฯลฯ)
# จาก https://resend.com/api-keys
RESEND_API_KEY=re_...

# --- Upstash Redis Cache ---
# จำเป็นสำหรับ: ระบบ cache (เนื้อหา, API responses)
# จาก Upstash Console > Redis > Details > REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Internal Secrets ---
# ใช้ยืนยันตัวตนระหว่าง service sync ภายใน
# API_SYNC_SECRET=<your-sync-secret>

# --- Optional ---
# URL หลักของเว็บ — ใช้ใน sitemap.xml และ robots.txt
NEXT_PUBLIC_SITE_URL=https://archron.app
