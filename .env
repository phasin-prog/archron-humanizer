# =============================================================================
# ARCHRON — Shared Defaults (non-sensitive)
# ค่าเริ่มต้นที่ปลอดภัยใช้ร่วมกันในทุก environment
# ค่าที่เป็น secrets/keys ใส่ใน .env.local แทน
# =============================================================================

# --- Clerk Auth (default paths) ---
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/th/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/th/register

# --- Cloudflare R2 (public defaults) ---
R2_BUCKET_NAME=archron

# --- Optional ---
# NEXT_PUBLIC_SITE_URL=https://archron.app
