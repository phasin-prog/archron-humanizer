{
  "name": "@archron/database",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "dependencies": {
    "@archron/shared": "workspace:*",
    "drizzle-orm": "^0.45",
    "postgres": "^3"
  },
  "devDependencies": {
    "typescript": "^6.0",
    "vitest": "^4",
    "drizzle-kit": "^0.31",
    "eslint": "^10",
    "@types/node": "^24",
    "@archron/vitest": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  }
}
